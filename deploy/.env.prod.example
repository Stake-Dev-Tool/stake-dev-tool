# Copy to deploy/.env.prod and edit. Never commit .env.prod.

# --- domains / TLS ---
APP_DOMAIN=app.stakedevtool.com
# Base of the wildcard share domains (M5): *.play.stakedevtool.com
PLAY_DOMAIN=play.stakedevtool.com
# Cloudflare API token (Zone -> DNS -> Edit) for the wildcard DNS-01 cert (M5).
CLOUDFLARE_API_TOKEN=

# --- database ---
# Also composed into DATABASE_URL by docker-compose.prod.yml.
POSTGRES_PASSWORD=change-me-long-random

# --- server ---
SERVER_BIND_ADDR=0.0.0.0:8080
SERVER_PUBLIC_URL=https://app.stakedevtool.com
SERVER_COOKIE_SECURE=true
RUST_LOG=info

# --- object storage ---
# Hosted instance: Cloudflare R2 (S3-compatible, zero egress fees).
# Self-host: keep STORAGE_BACKEND=fs (blobs land in the blobdata volume).
STORAGE_BACKEND=fs
# STORAGE_BACKEND=s3
# STORAGE_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# STORAGE_S3_BUCKET=stake-dev
# STORAGE_S3_REGION=auto
# STORAGE_S3_ACCESS_KEY_ID=
# STORAGE_S3_SECRET_ACCESS_KEY=

# --- auth extras (optional) ---
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# Discord OAuth. Same rule as GitHub (id + secret + SERVER_PUBLIC_URL); register
# the redirect <SERVER_PUBLIC_URL>/api/auth/discord/callback and the "email"
# scope in the Discord Developer Portal. Unset → discord routes 404.
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=

# --- transactional email (Resend; optional) ---
# Powers password-reset links and signup email verification. Set BOTH to enable.
# Unset → forgot-password still 200s (no mail sent) and new signups are created
# already-verified. MAIL_FROM must use a domain verified in your Resend account.
# RESEND_API_KEY=
# MAIL_FROM=Stake Dev Tool Cloud <no-reply@stakedevtool.com>

# --- instance admin ---
# Comma-separated email allowlist for platform operators. A listed account gets
# the admin surface (/api/admin/*: global stats, workspace plan overrides / comp
# subscriptions, user management, share moderation) even without the
# users.is_admin flag — this bootstraps the first admin without any SQL. Entries
# are trimmed + lowercased; non-admins get a 404 (the surface is never revealed).
# Set this to your own email before first boot, then manage further admins in-app.
# SERVER_ADMIN_EMAILS=you@example.com

# --- billing (Stripe; optional) ---
# Set all of the following to enable metered plans + quotas. Unset → the instance
# runs unlimited with the billing routes returning 404. The webhook secret backs
# the Stripe-Signature check on POST /api/billing/webhook; point the Stripe
# webhook endpoint at https://<APP_DOMAIN>/api/billing/webhook and paste its
# signing secret below. Swap the sk_test_…/test-mode price ids for sk_live_…/live
# price ids to go live — the API host is always api.stripe.com, no env flag.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_SOLO_MONTHLY=
# STRIPE_PRICE_SOLO_YEARLY=
# STRIPE_PRICE_TEAM_MONTHLY=
# STRIPE_PRICE_TEAM_YEARLY=
# Quantity-based storage add-on (one unit = +10 GiB, €1/mo).
# STRIPE_PRICE_STORAGE=
