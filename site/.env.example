# Public URL of the deployed site (used for checkout redirects)
SITE_URL=https://stakedevtool.com

# Lemon Squeezy (merchant of record — handles payment + VAT remittance)
# API key: Settings → API in the Lemon Squeezy dashboard
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=

# Variant IDs for each plan/interval (Products → variant → copy ID)
LEMONSQUEEZY_VARIANT_SOLO_MONTHLY=
LEMONSQUEEZY_VARIANT_SOLO_YEARLY=
LEMONSQUEEZY_VARIANT_TEAM_MONTHLY=
LEMONSQUEEZY_VARIANT_TEAM_YEARLY=

# Webhook signing secret (Settings → Webhooks → endpoint /api/billing/webhook)
LEMONSQUEEZY_WEBHOOK_SECRET=
