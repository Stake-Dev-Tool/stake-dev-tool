# Public URL of the deployed site (used for checkout redirects)
SITE_URL=https://stakedevtool.com

# Polar (merchant of record — handles payment + VAT remittance)
# Organization access token: Settings → Developers in the Polar dashboard.
# Set POLAR_SERVER=sandbox to test against sandbox.polar.sh.
POLAR_ACCESS_TOKEN=
POLAR_SERVER=production

# Product IDs — one product per plan/interval in Polar
# (each Polar product has a single billing cycle, so create four:
# Solo Monthly, Solo Yearly, Team Monthly, Team Yearly)
POLAR_PRODUCT_SOLO_MONTHLY=
POLAR_PRODUCT_SOLO_YEARLY=
POLAR_PRODUCT_TEAM_MONTHLY=
POLAR_PRODUCT_TEAM_YEARLY=

# Webhook signing secret (Settings → Webhooks → endpoint /api/billing/webhook)
POLAR_WEBHOOK_SECRET=
