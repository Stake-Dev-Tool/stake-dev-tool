# Copy to `.env` for local development. Defaults match docker-compose.dev.yml.

# HTTP bind address for the server.
SERVER_BIND_ADDR=127.0.0.1:8080

# Postgres connection string (docker-compose maps Postgres to host port 5433).
DATABASE_URL=postgres://stakedev:stakedev@localhost:5433/stakedev

# Object store backend: "fs" (local directory) or "s3" (S3-compatible).
STORAGE_BACKEND=fs

# Maximum bytes accepted for a single blob upload (default 8 GiB =
# 8589934592). A streamed body larger than this is aborted with 413.
# STORAGE_MAX_BLOB_BYTES=8589934592

# Byte budget for the multi-tenant LGS host's on-disk materialized-revision
# cache (default 20 GiB = 21474836480). Revisions are streamed from the object
# store to <STORAGE_FS_ROOT>/../cache (or ./data/cache for the s3 backend);
# least-recently-used completed revisions are evicted past this budget.
# SERVER_MATH_CACHE_BYTES=21474836480

# Optional per-tenant decompressed-books cap (bytes) for hosted LGS tenants.
# Unset (default) leaves tenants sharing the process-global books budget.
# SERVER_TENANT_BOOKS_CAP_BYTES=

# --- fs backend ---
STORAGE_FS_ROOT=./data/blobs

# --- s3 backend (uncomment STORAGE_BACKEND=s3 above to use the MinIO service) ---
# STORAGE_S3_ENDPOINT=http://localhost:9000
# STORAGE_S3_BUCKET=stake-dev
# STORAGE_S3_REGION=auto
# STORAGE_S3_ACCESS_KEY_ID=minioadmin
# STORAGE_S3_SECRET_ACCESS_KEY=minioadmin
# STORAGE_S3_ALLOW_HTTP=true

# --- auth / sessions ---

# `Secure` flag on the session cookie. Keep false for local http dev; set true
# behind TLS in production (otherwise browsers drop the cookie).
SERVER_COOKIE_SECURE=false

# Externally reachable base URL, used to build invite/device links and the
# GitHub OAuth redirect. Falls back to http://<SERVER_BIND_ADDR> when unset.
# SERVER_PUBLIC_URL=https://app.example.com

# Reverse-proxy networks whose forwarding headers we trust, comma-separated IPs
# or CIDRs (e.g. "127.0.0.1/32,::1/128"). The rate limiters honor an incoming
# X-Forwarded-For / X-Real-IP ONLY when the direct socket peer is inside one of
# these networks; from any other peer the headers are ignored and the real socket
# address is used (so a client can't spoof X-Forwarded-For to dodge the per-IP
# login limit). Empty/unset (the default) trusts no proxy — correct when the
# server is reached directly. Set this to your proxy's address when the server
# sits behind one. In production we run Caddy on the same host (loopback peer),
# so the deploy example sets "127.0.0.1/32,::1/128".
# SERVER_TRUSTED_PROXIES=127.0.0.1/32,::1/128

# GitHub OAuth (optional). All three of the following (client id, client secret,
# and SERVER_PUBLIC_URL above) must be set to enable it; otherwise the GitHub
# routes return 404 and /api/auth/providers reports "github": false.
# GITHUB_CLIENT_ID=your-client-id
# GITHUB_CLIENT_SECRET=your-client-secret

# Discord OAuth (optional). Same rule as GitHub: client id, client secret, and
# SERVER_PUBLIC_URL must all be set, else the /api/auth/discord/* routes return
# 404 and providers reports "discord": false. Add the redirect URL
# <SERVER_PUBLIC_URL>/api/auth/discord/callback in the Discord Developer Portal,
# and enable the "email" scope (an unverified/absent email is rejected at login).
# DISCORD_CLIENT_ID=your-client-id
# DISCORD_CLIENT_SECRET=your-client-secret

# --- transactional email (Resend; optional) ---

# Email sending powers password-reset links and signup email verification. Both
# of the following must be set to enable it; otherwise the forgot-password
# endpoint still answers 200 (logging a warning) and new signups are created
# already-verified (no verification step exists without mail). The API key is a
# Resend key (re_…); MAIL_FROM must use a domain verified in your Resend account.
# RESEND_API_KEY=re_your_key
# MAIL_FROM=Stake Dev Tool Cloud <no-reply@stakedevtool.com>

# Dashboard static build directory. Unset = auto-detect ./web/build (packaged)
# then <repo>/web/build (cargo run from the workspace root). Build it with
# `pnpm --filter web build`; without it the server runs API-only.
# SERVER_WEB_DIR=./web/build

# tracing env-filter (e.g. "info", "server=debug,info").
RUST_LOG=info

# --- instance admin ---

# Comma-separated email allowlist for instance operators (platform admins). An
# account whose email is listed here gets the admin surface (/api/admin/*) even
# without the users.is_admin flag — this is how the FIRST admin is bootstrapped,
# before any admin exists to grant the flag. Entries are trimmed and lowercased;
# empty/unset grants no one, and non-admins get a 404 on every admin route (the
# surface is never revealed with a 403). Once bootstrapped, an admin can flip
# is_admin on other accounts from the admin UI.
# SERVER_ADMIN_EMAILS=you@example.com,ops@example.com

# Set to enable the real-database integration test: cargo test -p server
# TEST_DATABASE_URL=postgres://stakedev:stakedev@localhost:5433/stakedev

# --- billing (Stripe; optional) ---

# Stripe billing activates only when the secret key, the webhook secret, AND all
# five price ids below are set; otherwise the billing routes 404, every workspace
# resolves to unlimited, and no quota is ever enforced (the permanent state for
# self-hosters). Create the products/prices in the Stripe dashboard
# (https://dashboard.stripe.com) and copy their price ids (price_…) here. Test vs
# live is chosen purely by the key/price ids you supply (sk_test_…/price_… from
# test mode, sk_live_…/price_… from live) — there is no separate environment flag.
# The webhook secret backs the Stripe-Signature check on POST /api/billing/webhook.
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# Per-seat subscription price (graduated tiers: first seat then each extra).
# STRIPE_PRICE_SEAT_MONTHLY=price_xxx
# STRIPE_PRICE_SEAT_YEARLY=price_xxx
# Quantity-based storage add-on (one unit = +10 GiB, €1/mo).
# STRIPE_PRICE_STORAGE=price_xxx
# Optional: Customer Portal configuration id (bpc_…) used for the "Manage billing"
# session (payment method, invoices, cancel). Leave unset to use the Stripe
# account's default portal configuration.
# STRIPE_PORTAL_CONFIGURATION=bpc_xxx
