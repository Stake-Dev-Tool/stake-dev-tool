# Copy to `.env` for local development. Defaults match docker-compose.dev.yml.

# HTTP bind address for the server.
SERVER_BIND_ADDR=127.0.0.1:8080

# Postgres connection string (docker-compose maps Postgres to host port 5433).
DATABASE_URL=postgres://stakedev:stakedev@localhost:5433/stakedev

# Object store backend: "fs" (local directory) or "s3" (S3-compatible).
STORAGE_BACKEND=fs

# --- fs backend ---
STORAGE_FS_ROOT=./data/blobs

# --- s3 backend (uncomment STORAGE_BACKEND=s3 above to use the MinIO service) ---
# STORAGE_S3_ENDPOINT=http://localhost:9000
# STORAGE_S3_BUCKET=stake-dev
# STORAGE_S3_REGION=auto
# STORAGE_S3_ACCESS_KEY_ID=minioadmin
# STORAGE_S3_SECRET_ACCESS_KEY=minioadmin
# STORAGE_S3_ALLOW_HTTP=true

# --- auth / sessions ---

# `Secure` flag on the session cookie. Keep false for local http dev; set true
# behind TLS in production (otherwise browsers drop the cookie).
SERVER_COOKIE_SECURE=false

# Externally reachable base URL, used to build invite/device links and the
# GitHub OAuth redirect. Falls back to http://<SERVER_BIND_ADDR> when unset.
# SERVER_PUBLIC_URL=https://app.example.com

# GitHub OAuth (optional). All three of the following (client id, client secret,
# and SERVER_PUBLIC_URL above) must be set to enable it; otherwise the GitHub
# routes return 404 and /api/auth/providers reports "github": false.
# GITHUB_CLIENT_ID=your-client-id
# GITHUB_CLIENT_SECRET=your-client-secret

# Dashboard static build directory. Unset = auto-detect ./web/build (packaged)
# then <repo>/web/build (cargo run from the workspace root). Build it with
# `pnpm --filter web build`; without it the server runs API-only.
# SERVER_WEB_DIR=./web/build

# tracing env-filter (e.g. "info", "server=debug,info").
RUST_LOG=info

# Set to enable the real-database integration test: cargo test -p server
# TEST_DATABASE_URL=postgres://stakedev:stakedev@localhost:5433/stakedev
